{
  "name": "langgraph-agent-orchestration",
  "version": "1.0.0",
  "description": "AI Agent Orchestration System using LangGraph with multi-provider LLM support",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node --max-old-space-size=4096 ./node_modules/.bin/tsc",
    "start": "node dist/server.js",
    "demo": "tsx examples/demo.ts",
    "lint": "eslint src/ --ext .ts",
    "type-check": "node --max-old-space-size=4096 ./node_modules/.bin/tsc --noEmit"
  },
  "keywords": [
    "langgraph",
    "langchain",
    "ai-agents",
    "llm",
    "openai",
    "anthropic",
    "ollama",
    "typescript"
  ],
  "author": "Vinay Chintala",
  "license": "MIT",
  "dependencies": {
    "@langchain/anthropic": "^0.3.7",
    "@langchain/community": "^0.3.15",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/langgraph": "^0.2.19",
    "@langchain/openai": "^0.3.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mongodb": "^6.12.0",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
